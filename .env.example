# SpaceLaunchNow API Configuration
# 
# This is an example .env file. To use:
# 1. Copy this file to .env (remove the .example extension)
# 2. Replace the placeholder values with your actual API keys
# 3. The application will automatically load these values at runtime

# The Space Devs API Key
API_KEY=your_api_key_here

# RevenueCat API Keys
REVENUECAT_ANDROID_KEY=your_revenuecat_android_key_here
REVENUECAT_IOS_KEY=your_revenuecat_ios_key_here
