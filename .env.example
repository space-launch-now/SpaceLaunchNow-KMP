# SpaceLaunchNow API Configuration
# 
# This is an example .env file. To use:
# 1. Copy this file to .env (remove the .example extension)
# 2. Replace the placeholder values with your actual API keys
# 3. The application will automatically load these values at runtime

# The Space Devs API Key
API_KEY=your_api_key_here

# RevenueCat API Keys
REVENUECAT_ANDROID_KEY=your_revenuecat_android_key_here
REVENUECAT_IOS_KEY=your_revenuecat_ios_key_here

# TOTP Secret for Debug Menu Authentication
TOTP_SECRET=

# Debug Mode Configuration
# Android: Automatically set by build type (debug/release) - this value is ignored
# iOS: Must be explicitly set since Xcode build schemes don't integrate with Gradle
#      - Set to "true" for development/debug builds (enables test ads, debug logging)
#      - Set to "false" or omit for production builds (uses real ads, minimal logging)
#      - Defaults to "false" if not set (production-safe)
# CI/CD: Ensure this is set correctly for each build type
DEBUG=false

# AdMob Ad Unit IDs (Production)
# Get these from https://admob.google.com/ > Your App > Ad units
# IMPORTANT: Use PRODUCTION ad unit IDs here, not test IDs
# Test ads are automatically shown in debug builds

# Production Banner Ad Unit IDs
ANDROID_BANNER_AD_UNIT_ID=
IOS_BANNER_AD_UNIT_ID=

# Production Interstitial Ad Unit IDs
ANDROID_INTERSTITIAL_AD_UNIT_ID=
IOS_INTERSTITIAL_AD_UNIT_ID=

# Production Rewarded Ad Unit IDs (Premium Trial = 1)
ANDROID_REWARDED_AD_UNIT_ID=
IOS_REWARDED_AD_UNIT_ID=

DEBUG=