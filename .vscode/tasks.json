{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start ADB Server",
            "detail": "Starts the adb server if it isn't already running (idempotent).",
            "type": "shell",
            "command": "adb",
            "args": [
                "start-server"
            ],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Desktop App",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                "desktopRun",
                "--quiet"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Desktop App",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                "compileKotlinDesktop"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Debug",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                "installDebug",
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Regenerate API",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                "openApiGenerate"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                "test"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
